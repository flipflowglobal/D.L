# ─────────────────────────────────────────────────────────────────────────────
# AUREON — Environment Variable Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. vault/wallet.json is also excluded via .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ── Ethereum RPC (REQUIRED for live trading) ──────────────────────────────────
# Option A: Paste your full Alchemy HTTPS URL (recommended)
#   Get a free key at https://www.alchemy.com → Create App → Ethereum Mainnet
#   Copy the HTTPS URL, e.g.:
#     https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
RPC_URL=

# Option B: Provide just the Alchemy API key — the full URL is auto-derived
ALCHEMY_API_KEY=

# ETH_RPC is an alias for RPC_URL accepted by some modules
ETH_RPC=

# Chain ID: 1 = Ethereum Mainnet, 11155111 = Sepolia testnet
CHAIN_ID=1


# ── Wallet (filled automatically by setup_wallet.py) ─────────────────────────
WALLET_ADDRESS=
PRIVATE_KEY=


# ── Trading parameters (all optional — defaults shown) ───────────────────────

# Seconds between price-check cycles
SCAN_INTERVAL=30

# ETH amount to buy/sell per trade
TRADE_SIZE_ETH=0.05

# Minimum estimated profit (USD) before executing an arbitrage trade
MIN_PROFIT_USD=2.0

# Maximum gas cost (USD) allowed per transaction
GAS_BUDGET_USD=5.0

# Starting USD balance for paper-trading P&L calculation
INITIAL_USD=10000

# Risk guard: max trades executed in a single calendar day
MAX_DAILY_TRADES=20

# Risk guard: max USD value of a single position
MAX_POSITION_USD=2000


# ── Strategy parameters (optional) ───────────────────────────────────────────

# Number of price samples in the mean-reversion rolling window
STRATEGY_WINDOW=12

# Fraction of mean deviation required to trigger BUY/SELL (0.015 = 1.5 %)
STRATEGY_THRESHOLD=0.015


# ── DL_SYSTEM quest automation (optional) ────────────────────────────────────
GALXE_EMAIL=
GALXE_PASSWORD=
LAYER3_EMAIL=
LAYER3_PASSWORD=


# ── Transaction confirmation (optional — defaults shown) ──────────────────────

# Seconds to wait for a transaction to be mined before timing out
TX_CONFIRM_TIMEOUT=120

# Seconds before bumping gas on a stuck transaction (EIP-1559 replacement)
TX_BUMP_TIMEOUT=45

# Maximum gas limit per transaction (hard safety cap)
MAX_GAS_LIMIT=500000

# EIP-1559 fee buffer: maxFeePerGas = baseFee × this multiplier + priority fee
# 1.15 absorbs one full block of 12.5% base fee increase with 2.5% margin
GAS_FEE_BUFFER_MULTIPLIER=1.15

# Default miner tip (gwei) used when the Alchemy oracle is unavailable
DEFAULT_PRIORITY_FEE_GWEI=2.0




# Deployed IFlashLoanReceiver contract address (required for live flash loans)
FLASH_RECEIVER_ADDRESS=

# Wallet that receives flash loan profits
PROFIT_WALLET=

# Amount of WETH to borrow in a flash loan (default: 0.01)
FLASH_LOAN_AMOUNT_ETH=0.01

# Set to false to actually broadcast flash loan transactions
DRY_RUN=true

# Aave V3 Sepolia Pool (official — change for mainnet)
AAVE_POOL_ADDRESS=0x6Ae43d3271ff6888e7Fc43Fd7321a503ff738951

# WETH token on Sepolia for Aave V3
WETH_ADDRESS=0xC558DBdd856501FCd9aaF1E62eae57A9F0629a3c

# Uniswap V3 SwapRouter on Sepolia
UNISWAP_ROUTER_ADDRESS=0xE592427A0AEce92De3Edee1F18E0157C05861564


# ── Test utilities ────────────────────────────────────────────────────────────

# Recipient address for send_test.py / send_testnet_tx.py
TEST_RECIPIENT=

# ETH amount for test send (default: 0.001)
TEST_AMOUNT_ETH=0.001


# ── Base44 agent API (optional) ───────────────────────────────────────────────
BASE44_API_KEY=
BASE44_API_URL=https://preview-sandbox--69b04a5bf0be8d0ff013b05a.base44.app
BASE44_AGENT_ID=aureon


# ── Debug / runtime ───────────────────────────────────────────────────────────
DEBUG=false

# Override ETH/USD fallback price used when CoinGecko is unavailable
FALLBACK_ETH_PRICE=2000.0


# ── Solana RPC (optional — used by blockchain_aureon.py) ─────────────────────
SOLANA_RPC=https://api.mainnet-beta.solana.com
